{
  "name": "harness",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first multi-agent Kanban execution framework.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @harness/server --filter @harness/web dev",
    "dev:server": "pnpm --filter @harness/server dev",
    "dev:web": "pnpm --filter @harness/web dev",
    "dev:desktop": "pnpm build && pnpm --filter @harness/desktop start",
    "start": "pnpm --filter @harness/server start",
    "cli": "pnpm --filter @harness/server cli",
    "smoke:quick-start": "bash scripts/quick-start-smoke.sh",
    "test": "pnpm --filter @harness/server test && pnpm --filter @harness/web test && pnpm --filter @harness/desktop test",
    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.7.0"
}
