{
  "name": "@harness/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test test/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "typescript": "^5.8.3"
  }
}
